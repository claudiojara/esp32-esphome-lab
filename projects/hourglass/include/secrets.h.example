// secrets.h - copiar a secrets.h y completar.
// El archivo `secrets.h` está gitignoreado en el .gitignore del root del repo.
//
// Uso: incluir este header en main.cpp con #include "secrets.h"

#pragma once

#define WIFI_SSID       "tu-red-wifi"
#define WIFI_PASSWORD   "tu-password"

// MQTT broker (Mosquitto addon en HA, normalmente el IP de HA en la LAN)
#define MQTT_HOST       "192.168.100.X"
#define MQTT_PORT       1883
#define MQTT_USER       "tu-mqtt-user"
#define MQTT_PASSWORD   "tu-mqtt-password"

// OTA password — usá el mismo que en secrets.yaml de los YAMLs ESPHome
// para mantener una sola password en todo el repo.
#define OTA_PASSWORD    "tu-ota-password"
